# Copy to `.env.local` (not committed). NEXT_PUBLIC_* is available in the browser.

# Light = Hebi, dark = Parsa (dock theme toggle). No profile env needed.

# Optional: Hebi light home — Spline **Export → Code** `…/scene.splinecode` (HTTP 200).
# Otherwise the built-in animated mesh is used.
# NEXT_PUBLIC_HOME_LIGHT_SPLINE_URL=https://prod.spline.design/YOUR_EXPORT_ID/scene.splinecode
